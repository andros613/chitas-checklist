---
import fs from 'node:fs';
import path from 'node:path';
import Layout from '../layouts/Layout.astro';
import HeroImage from '@andros613/theme/components/HeroImage.astro';

const pdfsDir = path.resolve('./public/pdfs');
const files = fs.readdirSync(pdfsDir)
  .filter(f => f.endsWith('.pdf'))
  .sort()
  .reverse(); // newest month first

// Determine current Hebrew month using the Intl API.
// Note: 'month: numeric' returns a name string (e.g. "Nisan"), not a number.
const hebrewParts = new Intl.DateTimeFormat('en-u-ca-hebrew', {
  year: 'numeric',
  month: 'long',
}).formatToParts(new Date());
const currentHeYear = parseInt((hebrewParts.find(p => p.type === 'year')?.value ?? '0').replace(/\D/g, ''), 10);
const currentHeMonthName = hebrewParts.find(p => p.type === 'month')?.value ?? '';

// Map Intl Hebrew month names → filename slugs
const INTL_TO_SLUG: Record<string, string> = {
  'Tishri': 'tishrei', 'Heshvan': 'cheshvan', 'Kislev': 'kislev',
  'Tevet': 'tevet', 'Shevat': 'shevat', 'Adar': 'adar',
  'Adar I': 'adar_i', 'Adar II': 'adar_ii',
  'Nisan': 'nissan', 'Iyar': 'iyar', 'Sivan': 'sivan',
  'Tamuz': 'tammuz', 'Av': 'av', 'Elul': 'elul',
};
const currentSlug = INTL_TO_SLUG[currentHeMonthName] ?? '';

function fileYear(filename: string): number {
  return parseInt(filename.split('_')[0], 10);
}
function fileSlug(filename: string): string {
  return filename.replace(/\.pdf$/, '').split('_').slice(2).join('_').toLowerCase();
}
function fileOrder(filename: string): number {
  const parts = filename.replace(/\.pdf$/, '').split('_');
  return parseInt(parts[0], 10) * 100 + parseInt(parts[1], 10);
}

// Match current month by year+slug; use its actual order for the past/upcoming split.
// This correctly handles leap years where month numbers shift.
const currentFile = files.find(f => fileYear(f) === currentHeYear && fileSlug(f) === currentSlug);
const currentOrderActual = currentFile ? fileOrder(currentFile) : NaN;

const currentFiles  = currentFile ? [currentFile] : [];
// upcoming: ascending order (next month first); past: descending (most recent first, already reversed)
const upcomingFiles = files.filter(f => isNaN(currentOrderActual) ? true : fileOrder(f) > currentOrderActual).reverse();
const pastFiles     = files.filter(f => isNaN(currentOrderActual) ? false : fileOrder(f) < currentOrderActual);

function displayName(filename: string): string {
  // e.g. "5786_07_nissan.pdf" → "Nissan 5786 (Mar-Apr 2026)"
  const stem = filename.replace(/\.pdf$/, '');
  const parts = stem.split('_');
  if (parts.length < 3) return stem;

  const heYear = parseInt(parts[0], 10);
  const monthSlug = parts.slice(2).join('_').toLowerCase();
  const monthDisplay = monthSlug.split('_').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');

  // Hebrew month → Gregorian months + year offsets relative to Hebrew year
  // Offset = Gregorian year - Hebrew year (e.g. Nissan 5786 = 2026, offset = 2026-5786 = -3760)
  const GREG_MAP: Record<string, { months: string[]; offsets: number[] }> = {
    tishrei:  { months: ['Sep', 'Oct'], offsets: [-3761, -3761] },
    cheshvan: { months: ['Oct', 'Nov'], offsets: [-3761, -3761] },
    kislev:   { months: ['Nov', 'Dec'], offsets: [-3761, -3761] },
    tevet:    { months: ['Dec', 'Jan'], offsets: [-3761, -3760] }, // spans Gregorian year
    shevat:   { months: ['Jan', 'Feb'], offsets: [-3760, -3760] },
    adar:     { months: ['Feb', 'Mar'], offsets: [-3760, -3760] },
    adar_i:   { months: ['Feb', 'Mar'], offsets: [-3760, -3760] },
    adar_ii:  { months: ['Mar'],        offsets: [-3760] },
    nissan:   { months: ['Mar', 'Apr'], offsets: [-3760, -3760] },
    iyar:     { months: ['Apr', 'May'], offsets: [-3760, -3760] },
    sivan:    { months: ['May', 'Jun'], offsets: [-3760, -3760] },
    tammuz:   { months: ['Jun', 'Jul'], offsets: [-3760, -3760] },
    av:       { months: ['Jul', 'Aug'], offsets: [-3760, -3760] },
    elul:     { months: ['Aug', 'Sep'], offsets: [-3760, -3760] },
  };

  const info = GREG_MAP[monthSlug];
  let gregSuffix = '';
  if (info) {
    const y1 = heYear + info.offsets[0];
    if (info.months.length === 1) {
      gregSuffix = ` (${info.months[0]} ${y1})`;
    } else {
      const y2 = heYear + info.offsets[1];
      gregSuffix = y1 === y2
        ? ` (${info.months[0]}-${info.months[1]} ${y1})`
        : ` (${info.months[0]} ${y1} - ${info.months[1]} ${y2})`;
    }
  }

  return `${monthDisplay} ${heYear}${gregSuffix}`;
}

const base = import.meta.env.BASE_URL;
---
<Layout title="Browse">
  <HeroImage
    src={`${base}temple_from_space_v02.png`}
    alt="Temple from space"
    title="Chitas Checklist"
    subtitle="Printable monthly checklists for daily Chitas — Chumash-Rashi, Tehillim, and Tanya."
    objectPosition="center 25%"
  />

  {currentFiles.length > 0 && (
    <section class="pdf-section">
      <h2 class="section-title current">Current Month</h2>
      {currentFiles.map(file => (
        <div class="pdf-item">
          <span class="pdf-icon">📄</span>
          <span class="pdf-name">{displayName(file)}</span>
          <a class="pdf-download" href={`${base}pdfs/${file}`} download={file}>↓ Download PDF</a>
        </div>
        <iframe class="pdf-viewer" src={`${base}pdfs/${file}`}></iframe>
      ))}
    </section>
  )}

  {upcomingFiles.length > 0 && (
    <section class="pdf-section">
      <h2 class="section-title">Upcoming</h2>
      <div class="pdf-list">
        {upcomingFiles.map(file => (
          <div class="pdf-item">
            <span class="pdf-icon">📄</span>
            <span class="pdf-name">{displayName(file)}</span>
            <a class="pdf-download" href={`${base}pdfs/${file}`} download={file}>↓ Download PDF</a>
          </div>
        ))}
      </div>
    </section>
  )}

  {pastFiles.length > 0 && (
    <section class="pdf-section">
      <details>
        <summary class="section-title past">Past Months</summary>
        <div class="pdf-list">
          {pastFiles.map(file => (
            <div class="pdf-item">
              <span class="pdf-icon">📄</span>
              <span class="pdf-name">{displayName(file)}</span>
              <a class="pdf-download" href={`${base}pdfs/${file}`} download={file}>↓ Download PDF</a>
            </div>
          ))}
        </div>
      </details>
    </section>
  )}
</Layout>


<style>
  .pdf-section {
    margin-bottom: 1.5rem;
  }

  .section-title {
    font-size: 1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #555;
    margin-bottom: 0.5rem;
    padding-bottom: 0.25rem;
    border-bottom: 1px solid #ddd;
  }

  .section-title.current {
    color: #1a6b2f;
  }

  details > summary.section-title {
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  details > summary.section-title::before {
    content: '▶';
    font-size: 0.65em;
    transition: transform 0.15s;
  }

  details[open] > summary.section-title::before {
    transform: rotate(90deg);
  }

  .pdf-viewer {
    display: block;
    width: 100%;
    height: 80vh;
    border: 1px solid #ccc;
    margin-top: 0.5rem;
    border-radius: 4px;
  }
</style>
